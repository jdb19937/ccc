# Faceplica — aedificatio ccc et ldi
#
# Usus:
#   face            — aedifica ccc et ldi
#   face purga      — dele omnia aedificata

CC      ?= cc
CFLAGS  ?= -Wall -Wextra -pedantic -std=c99 -O2

CAPITA  = ccc.h emitte.h scribo.h genera.h parser.h lexator.h liga.h biblio.h fluat.h

CCC_OBJECTA = ccc.o lexator.o parser.o genera.o emitte.o scribo.o biblio.o fluat.o
LDI_OBJECTA = ldi.o liga.o emitte.o scribo.o biblio.o
OBJECTA     = ccc.o ldi.o lexator.o parser.o genera.o emitte.o scribo.o liga.o biblio.o fluat.o

omnia: ccc ldi

%.o: %.c $(CAPITA)
	$(CC) $(CFLAGS) -c $< -o $@

ccc: $(CCC_OBJECTA)
	$(CC) $(CFLAGS) -o $@ $(CCC_OBJECTA)
	@echo "==> ccc aedificatum"

ldi: $(LDI_OBJECTA)
	$(CC) $(CFLAGS) -o $@ $(LDI_OBJECTA)
	@echo "==> ldi aedificatum"

PREFIX = /opt/apotheca

colloca: omnia
	install -d $(PREFIX)/bin
	install -m 755 ccc $(PREFIX)/bin/
	install -m 755 ldi $(PREFIX)/bin/

purga:
	rm -f $(OBJECTA) ccc ldi

linte:
	insinulint -c $(CAPITA)

.PHONY: omnia colloca purga linte
