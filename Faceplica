# Faceplica — aedificatio ccc et ldi
#
# Usus:
#   face            — aedifica ccc et ldi
#   face purga      — dele omnia aedificata

CC      ?= cc
CFLAGS  ?= -Wall -Wextra -pedantic -std=c99 -O2

CAPITA  = ccc.h emitte.h scribo.h genera.h parser.h lexator.h liga.h biblio.h fluat.h

CCC_OBJECTA = ccc.o lexator.o parser.o genera.o emitte.o scribo.o biblio.o fluat.o
LDI_OBJECTA = ldi.o liga.o emitte.o scribo.o biblio.o
OBJECTA     = ccc.o ldi.o lexator.o parser.o genera.o emitte.o scribo.o liga.o biblio.o fluat.o

omnia: ccc ldi

%.o: %.c $(CAPITA)
	$(CC) $(CFLAGS) -c $< -o $@

ccc: $(CCC_OBJECTA)
	$(CC) $(CFLAGS) -o $@ $(CCC_OBJECTA)
	@echo "==> ccc aedificatum"

ldi: $(LDI_OBJECTA)
	$(CC) $(CFLAGS) -o $@ $(LDI_OBJECTA)
	@echo "==> ldi aedificatum"

PREFIX = /opt/apotheca

colloca: omnia
	install -d $(PREFIX)/bin
	install -m 755 ccc $(PREFIX)/bin/
	install -m 755 ldi $(PREFIX)/bin/
	install -d $(PREFIX)/capita/sys
	install -m 644 capita/capitum.h $(PREFIX)/capita/
	for f in capita/*.h; do install -m 644 $$f $(PREFIX)/capita/; done
	for f in capita/sys/*.h; do install -m 644 $$f $(PREFIX)/capita/sys/; done

purga:
	rm -f $(OBJECTA) ccc ldi
	rm -f initia.fac reinitia.fac
	rm -rf initia reinitia

proba:
	./proba_corpus.sh casus
	./proba_corpus.sh silva
	$(FACE) initia
	# $(FACE) reinitia

linte:
	insinulint -c $(CAPITA)

initia.fac: ccc ldi
	rm -rf initia
	./initia.sh initia ../ccc ../ldi
	$(FACE) -C initia
	touch $@
initia:
	rm -f $@.fac
	$(FACE) $@.fac


reinitia.fac: initia.fac
	rm -rf reinitia
	./initia.sh reinitia ../initia/ccc ../initia/ldi
	$(FACE) -C reinitia
	touch $@
reinitia:
	rm -f $@.fac
	$(FACE) $@.fac

.PHONY: omnia colloca purga linte initia reinitia proba
