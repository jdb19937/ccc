# Faceplica — aedificatio ccc et ldi
#
# Usus:
#   face            — aedifica ccc et ldi
#   face purga      — dele omnia aedificata

CC      ?= cc
CFLAGS  ?= -Wall -Wextra -pedantic -std=c99 -O2

CAPITA  = utilia.h emitte.h emittesym.h scribo.h genera.h generasym.h parser.h lexator.h liga.h biblio.h fluat.h typus.h func.h

ICCC_OBJECTA  = iccc.o
CCC_OBJECTA = ccc.o utilia.o lexator.o parser.o generasym.o emittesym.o emitte.o biblio.o fluat.o typus.o func.o
CCC0_OBJECTA = ccc0.o utilia.o lexator.o parser.o genera.o emitte.o scribo.o biblio.o fluat.o typus.o func.o
LDI_OBJECTA = ldi.o utilia.o liga.o emitte.o scribo.o biblio.o typus.o func.o fluat.o
IMM_OBJECTA = imm.o utilia.o emitte.o scribo.o biblio.o fluat.o typus.o func.o
OBJECTA     = iccc.o ccc.o ccc0.o ldi.o imm.o utilia.o lexator.o parser.o genera.o generasym.o emitte.o emittesym.o scribo.o liga.o biblio.o fluat.o typus.o func.o

omnia: ccc ccc0 ldi iccc imm

%.o: %.c $(CAPITA)
	$(CC) $(CFLAGS) -c $< -o $@

iccc: $(ICCC_OBJECTA)
	$(CC) $(CFLAGS) -o $@ $(ICCC_OBJECTA)
	@echo "==> iccc aedificatum"

ccc: $(CCC_OBJECTA)
	$(CC) $(CFLAGS) -o $@ $(CCC_OBJECTA)
	@echo "==> ccc aedificatum"

ccc0: $(CCC0_OBJECTA)
	$(CC) $(CFLAGS) -o $@ $(CCC0_OBJECTA)
	@echo "==> ccc0 aedificatum"

ldi: $(LDI_OBJECTA)
	$(CC) $(CFLAGS) -o $@ $(LDI_OBJECTA)
	@echo "==> ldi aedificatum"

imm: $(IMM_OBJECTA)
	$(CC) $(CFLAGS) -o $@ $(IMM_OBJECTA)
	@echo "==> imm aedificatum"

PREFIX = /opt/apotheca

colloca: omnia
	install -d $(PREFIX)/bin
	install -m 755 iccc $(PREFIX)/bin/
	install -m 755 ccc $(PREFIX)/bin/
	install -m 755 ldi $(PREFIX)/bin/
	install -m 755 imm $(PREFIX)/bin/
	install -d $(PREFIX)/var/ccc/capita/sys
	install -d $(PREFIX)/var/ccc/capita/objc
	install -m 644 capita/capitum.h $(PREFIX)/var/ccc/capita/
	for f in capita/*.h; do install -m 644 $$f $(PREFIX)/var/ccc/capita/; done
	for f in capita/sys/*.h; do install -m 644 $$f $(PREFIX)/var/ccc/capita/sys/; done
	for f in capita/objc/*.h; do install -m 644 $$f $(PREFIX)/var/ccc/capita/objc/; done

purga:
	rm -f $(OBJECTA) ccc ccc0 ldi iccc imm
	rm -f initia.fac reinitia.fac
	rm -rf initia reinitia

proba:
	./proba_corpus.py ../corpus/casus
	./proba_corpus.py ../corpus/silva
	./proba_corpus.py ../corpus/cruces
	./proba_corpus.py ../corpus/linguae
	$(FACE) initia
	# $(FACE) reinitia

linte:
	insinulint -c *.c *.h

initia.fac: ccc ldi
	rm -rf initia
	./initia.sh initia ../ccc ../ldi
	$(FACE) -C initia
	touch $@
initia:
	rm -f $@.fac
	$(FACE) $@.fac


reinitia.fac: initia.fac
	rm -rf reinitia
	./initia.sh reinitia ../initia/ccc ../initia/ldi
	$(FACE) -C reinitia
	touch $@
reinitia:
	rm -f $@.fac
	$(FACE) $@.fac

.PHONY: omnia colloca purga linte initia reinitia proba
