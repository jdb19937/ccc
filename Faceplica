# Faceplica — aedificatio ccc et ldi
#
# Usus:
#   face            — aedifica ccc et ldi
#   face purga      — dele omnia aedificata

CC      ?= cc
CFLAGS  ?= -Wall -Wextra -pedantic -std=c99 -O2

CAPITA  = utilia.h emitte.h emittesym.h scribo.h generasym.h gsymconst.h generasym_intern.h parser.h parser_intern.h lexator.h liga.h biblio.h typus.h

LIBCCC_OBJECTA = \
    parser.o parser_typi.o parser_expr.o parser_sent.o lexator.o utilia.o typus.o
LIBCCC_CAPITA = \
    utilia.h parser.h parser_intern.h lexator.h typus.h
LIBLXIV_OBJECTA = \
    generasym.o gsymexpr.o gsymsent.o gsymconst.o gsymdata.o emittesym.o \
    emitte.o biblio.o scribo.o liga.o
LIBLXIV_CAPITA = \
    generasym.h generasym_intern.h gsymconst.h emittesym.h \
    emitte.h biblio.h scribo.h liga.h

CAPITA = $(LIBCCC_CAPITA) $(LIBLXIV_CAPITA)

omnia: ccc ldi iccc imm

%.o: %.c $(CAPITA)
	$(CC) $(CFLAGS) -c $< -o $@

libccc.a: $(LIBCCC_OBJECTA)
	ar rcs $@ $^

liblxiv.a: $(LIBLXIV_OBJECTA)
	ar rcs $@ $^

iccc: iccc.o
	$(CC) $(CFLAGS) -o $@ $^
	@echo "==> iccc aedificatum"

ccc: ccc.o libccc.a liblxiv.a
	$(CC) $(CFLAGS) -o $@ $^
	@echo "==> ccc aedificatum"

ldi: ldi.o libccc.a liblxiv.a
	$(CC) $(CFLAGS) -o $@ $^
	@echo "==> ldi aedificatum"

imm: imm.o libccc.a liblxiv.a
	$(CC) $(CFLAGS) -o $@ $^
	@echo "==> imm aedificatum"

PREFIX = /opt/apotheca

colloca: omnia
	install -d $(PREFIX)/bin
	install -m 755 iccc $(PREFIX)/bin/
	install -m 755 ccc $(PREFIX)/bin/
	install -m 755 ldi $(PREFIX)/bin/
	install -m 755 imm $(PREFIX)/bin/
	install -d $(PREFIX)/var/ccc/capita/sys
	install -d $(PREFIX)/var/ccc/capita/objc
	install -d $(PREFIX)/include/ccc/libccc
	install -d $(PREFIX)/include/ccc/liblxiv
	install -m 644 capita/capitum.h $(PREFIX)/var/ccc/capita/
	install -m 644 $(LIBCCC_CAPITA) $(PREFIX)/include/ccc/libccc
	install -m 644 $(LIBLXIV_CAPITA) $(PREFIX)/include/ccc/liblxiv
	install -d $(PREFIX)/lib
	install -m 644 libccc.a $(PREFIX)/lib
	install -m 644 liblxiv.a $(PREFIX)/lib
	for f in capita/*.h; do install -m 644 $$f $(PREFIX)/var/ccc/capita/; done
	for f in capita/sys/*.h; do install -m 644 $$f $(PREFIX)/var/ccc/capita/sys/; done
	for f in capita/objc/*.h; do install -m 644 $$f $(PREFIX)/var/ccc/capita/objc/; done

purga:
	rm -f $(LIBCCC_OBJECTA) $(LIBLXIV_OBJECTA) ccc.o ldi.o iccc.o imm.o
	rm -f ccc ldi iccc imm
	rm -f libccc.a liblxiv.a
	rm -f initia.fac reinitia.fac
	rm -rf initia reinitia

proba:
	./proba_corpus.py ../corpus/casus
	./proba_corpus.py ../corpus/silva
	./proba_corpus.py ../corpus/cruces
	./proba_corpus.py ../corpus/linguae
	$(FACE) initia
	# $(FACE) reinitia

linte:
	insinulint -c *.c *.h

initia.fac: ccc ldi
	rm -rf initia
	./initia.py initia ../ccc ../ldi
	$(FACE) -C initia
	touch $@
initia:
	rm -f $@.fac
	$(FACE) $@.fac


reinitia.fac: initia.fac
	rm -rf reinitia
	./initia.py reinitia ../initia/ccc ../initia/ldi
	$(FACE) -C reinitia
	touch $@
reinitia:
	rm -f $@.fac
	$(FACE) $@.fac

.PHONY: omnia colloca purga linte initia reinitia proba
